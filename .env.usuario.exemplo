# === PC DE USUARIO (quantos quiser) ===
# Renomeie este arquivo para  .env  e deixe ao lado do GestaoMAC.exe.
# Esta maquina SO LE (nao escreve coletas) e usa o banco compartilhado.

# Mesmo caminho de rede do coletor:
DB_PATH=\\SERVIDOR\Compartilhada\GestaoMAC\data\history.db

# 0 = somente leitura (nao disputa escrita no banco)
COLLECT_ON_OPEN=0

NEVER_MODE=grace
