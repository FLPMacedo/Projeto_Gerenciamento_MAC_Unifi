# Copie para .env (ao lado do .exe) e ajuste. NUNCA versione o .env real.
#
# A partir da v2 NAO e preciso colocar usuario/senha do UniFi aqui:
# o 1o login pela tela grava as credenciais (a senha fica criptografada no banco).
# As linhas UNIFI_* abaixo sao apenas "semente" opcional para o primeiro arranque.
# UNIFI_HOST=https://IP-DO-CONTROLLER
# UNIFI_SITE=default
# UNIFI_USERNAME=
# UNIFI_PASSWORD=
# UNIFI_VERIFY_SSL=false

# ---------------------------------------------------------------------------
# v2 - BANCO EM PASTA DE REDE (multiusuario, acesso simultaneo)
# Aponte para o MESMO arquivo numa pasta compartilhada (UNC). A chave de
# criptografia (secret.key) e criada/lida na MESMA pasta do banco.
# DB_PATH=\\SERVIDOR\Compartilhada\GestaoMAC\data\history.db

# Coleta distribuida (v4): por padrao TODOS coletam, mas um "lease" garante que
# so UM terminal coleta por janela (60s + 30s x conectados). Use 0 para marcar
# um PC como SOMENTE-VISUALIZACAO (nunca coleta):
COLLECT_ON_OPEN=1
# Janela base de coleta (segundos):
# COLLECT_BASE=60

# secret.key fica na RAIZ (ao lado do exe) por padrao. A MESMA chave deve estar
# em cada PC. Para apontar para outro local:
# KEY_PATH=C:\caminho\secret.key

# Tratamento de MAC que nunca conectou:
#   grace     -> so vira disponivel 35 dias apos a 1a coleta (protege cadastro novo)
#   immediate -> nunca logou ja conta como disponivel
NEVER_MODE=grace
